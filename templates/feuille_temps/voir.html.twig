{% extends 'base.html.twig' %}

{% block title %}Détails de la feuille de temps{% endblock %}

{% block body %}
<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_feuille_temps_index') }}">Feuilles de temps</a></li>
            <li class="breadcrumb-item active">Détails</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0">Feuille de temps du {{ feuille.dateTravail|date('d/m/Y') }}</h5>
            <span class="badge {% if feuille.statut == 'validé' %}bg-success{% elseif feuille.statut == 'rejeté' %}bg-danger{% else %}bg-secondary{% endif %}">
                {{ feuille.statut|capitalize }}
            </span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6>Mission</h6>
                    <p class="text-primary fw-bold">{{ feuille.affectation.tache.mission.noMission }}</p>
                    <p class="text-muted small">{{ feuille.affectation.tache.mission.client.nomClient }}</p>
                </div>
                <div class="col-md-6">
                    <h6>Tâche</h6>
                    <p class="fw-bold">{{ feuille.affectation.tache.libelleTache }}</p>
                    <p class="text-muted small">Rôle : {{ feuille.affectation.roleMission }}</p>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <h6>Heures effectuées</h6>
                    <p class="fs-4 fw-bold text-primary">{{ feuille.heuresEffectuees }} h</p>
                </div>
                <div class="col-md-4">
                    <h6>Date de soumission/validation</h6>
                    <p>{{ feuille.dateSoumission ? feuille.dateSoumission|date('d/m/Y H:i') : 'Non validé' }}</p>
                </div>
                <div class="col-md-4">
                    <h6>Date de validation</h6>
                    <p>{{ feuille.dateValidation ? feuille.dateValidation|date('d/m/Y H:i') : '-' }}</p>
                </div>
            </div>

            <div class="mb-4">
                <h6>Description du travail</h6>
                <div class="p-3 bg-light rounded text-muted">
                    {{ feuille.description|default('Aucune description fournie.')|nl2br }}
                </div>
            </div>

            {% if feuille.commentaireRejet %}
                <div class="alert alert-danger">
                    <h6><i class="fas fa-exclamation-triangle me-2"></i>Commentaire de rejet</h6>
                    {{ feuille.commentaireRejet }}
                </div>
            {% endif %}
        </div>
        <div class="card-footer bg-white py-3">
            <div class="d-flex gap-2">
                <a href="{{ path('app_feuille_temps_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
                {% if feuille.statut == 'brouillon' %}
                    <a href="{{ path('app_feuille_temps_editer', {'id': feuille.id}) }}" class="btn btn-warning">Modifier</a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
