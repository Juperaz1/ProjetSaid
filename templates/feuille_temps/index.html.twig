{# templates/feuille_temps/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mes feuilles de temps - Application{% endblock %}

{% block body %}
<div class="min-vh-100 bg-light">
    <!-- En-tête -->
    <div class="bg-white border-bottom">
        <div class="container py-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h1 class="h2 mb-1">Mes feuilles de temps</h1>
                    <p class="text-muted mb-0">
                        <i class="far fa-clock me-2"></i>Saisissez et suivez vos heures de travail
                    </p>
                </div>
                <div>
                    <a href="{{ path('app_feuille_temps_nouvelle') }}" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-2"></i>Nouvelle saisie
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Messages flash -->
    <div class="container py-3">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }} alert-dismissible fade show" role="alert">
                    <i class="fas fa-{{ label == 'error' ? 'exclamation-circle' : 'check-circle' }} me-2"></i>
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- Filtres et recherche -->
    <div class="container py-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Période</label>
                        <select name="periode" class="form-select">
                            <option value="ce_mois" {{ filtres.periode == 'ce_mois' ? 'selected' : '' }}>Ce mois</option>
                            <option value="mois_dernier" {{ filtres.periode == 'mois_dernier' ? 'selected' : '' }}>Mois dernier</option>
                            <option value="7_jours" {{ filtres.periode == '7_jours' ? 'selected' : '' }}>7 derniers jours</option>
                            <option value="30_jours" {{ filtres.periode == '30_jours' ? 'selected' : '' }}>30 derniers jours</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted">Statut</label>
                        <select name="statut" class="form-select">
                            <option value="tous" {{ filtres.statut == 'tous' ? 'selected' : '' }}>Tous les statuts</option>
                            <option value="brouillon" {{ filtres.statut == 'brouillon' ? 'selected' : '' }}>Brouillon</option>
                            <option value="soumis" {{ filtres.statut == 'soumis' ? 'selected' : '' }}>Soumis</option>
                            <option value="validé" {{ filtres.statut == 'validé' ? 'selected' : '' }}>Validé</option>
                            <option value="rejeté" {{ filtres.statut == 'rejeté' ? 'selected' : '' }}>Rejeté</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small text-muted">Mission</label>
                        <select name="mission" class="form-select">
                            <option value="">Toutes les missions</option>
                            {% for mission in missions %}
                                <option value="{{ mission.id }}" {{ filtres.mission == mission.id ? 'selected' : '' }}>
                                    {{ mission.noMission }} - {{ mission.client.nomClient ?? 'N/A' }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-outline-primary w-100">
                            <i class="fas fa-filter me-2"></i>Filtrer
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Résumé des heures -->
        <div class="row g-4 mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                                    <i class="fas fa-clock text-primary fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Total heures</h6>
                                <h3 class="mb-0">{{ stats.total_heures|number_format(1) }}</h3>
                                <small class="text-muted">Période sélectionnée</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                                    <i class="fas fa-check-circle text-success fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Validées</h6>
                                <h3 class="mb-0">{{ stats.heures_validees|number_format(1) }}</h3>
                                <small class="text-muted">
                                    {% if stats.total_heures > 0 %}
                                        {{ ((stats.heures_validees / stats.total_heures) * 100)|number_format(0) }}% du total
                                    {% else %}
                                        0% du total
                                    {% endif %}
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                                    <i class="fas fa-hourglass-half text-warning fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">En attente</h6>
                                <h3 class="mb-0">{{ stats.heures_soumises|number_format(1) }}</h3>
                                <small class="text-muted">Soumis</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                                    <i class="fas fa-pen text-info fs-4"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="text-muted mb-1">Brouillons</h6>
                                <h3 class="mb-0">{{ stats.heures_brouillon|number_format(1) }}</h3>
                                <small class="text-muted">À finaliser</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Liste des feuilles de temps -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4">
                <h5 class="mb-0">Historique des saisies</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Mission</th>
                                <th>Tâche</th>
                                <th>Heures</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for feuille in feuillesTemps %}
                            <tr>
                                <td>
                                    <span class="fw-semibold">{{ feuille.dateTravail|date('d/m/Y') }}</span>
                                    <small class="d-block text-muted">{{ feuille.dateTravail|date('l')|trans }}</small>
                                </td>
                                <td>
                                    {% if feuille.affectation.tache.mission is defined and feuille.affectation.tache.mission %}
                                        <span class="fw-semibold">{{ feuille.affectation.tache.mission.noMission }}</span>
                                        <small class="d-block text-muted">
                                            {{ feuille.affectation.tache.mission.client.nomClient ?? 'N/A' }}
                                        </small>
                                    {% else %}
                                        <span class="text-muted">Non assigné</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span>{{ feuille.affectation.tache.libelleTache ?? 'N/A' }}</span>
                                    <small class="d-block text-muted">{{ feuille.affectation.role ?? '' }}</small>
                                </td>
                                <td>
                                    <span class="fw-bold">{{ feuille.heuresEffectuees }}h</span>
                                </td>
                                <td>
                                    {% if feuille.statut == 'validé' %}
                                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                                            <i class="fas fa-check-circle me-1"></i>Validé
                                        </span>
                                    {% elseif feuille.statut == 'soumis' %}
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill">
                                            <i class="fas fa-hourglass-half me-1"></i>Soumis
                                        </span>
                                    {% elseif feuille.statut == 'rejeté' %}
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill">
                                            <i class="fas fa-times-circle me-1"></i>Rejeté
                                        </span>
                                    {% else %}
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2 rounded-pill">
                                            <i class="fas fa-pen me-1"></i>Brouillon
                                        </span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a href="{{ path('app_feuille_temps_voir', {'id': feuille.id}) }}" 
                                           class="btn btn-sm btn-outline-primary" 
                                           data-bs-toggle="tooltip" 
                                           title="Voir détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        {% if feuille.statut == 'brouillon' or feuille.statut == 'rejeté' %}
                                        <a href="{{ path('app_feuille_temps_editer', {'id': feuille.id}) }}" 
                                           class="btn btn-sm btn-outline-warning"
                                           data-bs-toggle="tooltip" 
                                           title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-success"
                                                data-bs-toggle="tooltip" 
                                                title="Soumettre"
                                                onclick="soumettreFeuille({{ feuille.id }})">
                                            <i class="fas fa-paper-plane"></i>
                                        </button>
                                        {% endif %}
                                        <a href="{{ path('app_feuille_temps_pdf', {'id': feuille.id}) }}" 
                                           class="btn btn-sm btn-outline-secondary"
                                           data-bs-toggle="tooltip" 
                                           title="Télécharger PDF">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fas fa-clock fs-1 mb-3 d-block"></i>
                                        <h5>Aucune feuille de temps trouvée</h5>
                                        <p>Commencez par saisir vos premières heures de travail</p>
                                        <a href="{{ path('app_feuille_temps_nouvelle') }}" class="btn btn-primary">
                                            <i class="fas fa-plus-circle me-2"></i>Nouvelle saisie
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function soumettreFeuille(id) {
    if (confirm('Voulez-vous soumettre cette feuille de temps pour validation ?')) {
        fetch('/feuille-temps/' + id + '/soumettre', {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.message || 'Une erreur est survenue');
            }
        })
        .catch(error => {
            alert('Erreur lors de la soumission');
            console.error(error);
        });
    }
}

</script>
{% endblock %}