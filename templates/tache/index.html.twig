{# templates/tache/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mes Tâches - Application{% endblock %}

{% block body %}
<div class="min-vh-100 bg-light">
    <!-- En-tête -->
    <div class="bg-white border-bottom">
        <div class="container py-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h1 class="h2 mb-1">Mes Tâches</h1>
                    <p class="text-muted mb-0">
                        <i class="fas fa-tasks me-2"></i>Retrouvez toutes les tâches qui vous sont assignées
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Messages flash -->
    <div class="container py-3">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }} alert-dismissible fade show shadow-sm" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- Liste des Tâches -->
    <div class="container py-4">
        {% if affectations is empty %}
            <div class="text-center py-5 bg-white rounded shadow-sm">
                <i class="fas fa-clipboard-check text-muted mb-3" style="font-size: 3rem;"></i>
                <h4 class="text-muted">Aucune tâche assignée</h4>
                <p class="text-secondary">Vous n'avez actuellement aucune tâche active assignée à votre profil.</p>
                <a href="{{ path('app_dashboard') }}" class="btn btn-primary mt-3">Retour au tableau de bord</a>
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                {% for affectation in affectations %}
                    {% set tache = affectation.tache %}
                    {% set mission = tache.mission %}
                    
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm hover-shadow transition">
                            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge bg-primary bg-opacity-10 text-primary mb-2">
                                        {{ mission.noMission }}
                                    </span>
                                </div>
                                <div>
                                    {% if tache.statut == 'terminée' %}
                                        <span class="badge bg-success">Terminée</span>
                                    {% elseif tache.statut == 'en cours' %}
                                        <span class="badge bg-primary">En cours</span>
                                    {% elseif tache.statut == 'bloquée' %}
                                        <span class="badge bg-danger">Bloquée</span>
                                    {% else %}
                                        <span class="badge bg-secondary text-dark">À faire</span>
                                    {% endif %}
                                </div>
                            </div>
                            
                            <div class="card-body">
                                <h5 class="card-title fw-bold mb-1">{{ tache.libelleTache }}</h5>
                                <h6 class="card-subtitle mb-3 text-muted">
                                    <i class="far fa-building me-1"></i> {{ mission.client.nomClient ?? 'Client non spécifié' }}
                                </h6>
                                
                                <div class="mb-3">
                                    <small class="text-muted d-block mb-1">Votre rôle :</small>
                                    <span class="badge bg-light text-dark border"><i class="fas fa-user-tag me-1"></i>{{ affectation.roleMission }}</span>
                                </div>
                                
                                {% if tache.description %}
                                <p class="card-text text-secondary small line-clamp-2" title="{{ tache.description }}">
                                    {{ tache.description }}
                                </p>
                                {% endif %}
                                
                                <ul class="list-unstyled mb-0 small text-muted mt-3 pt-3 border-top">
                                    {% if tache.dateFinPrevue %}
                                    <li class="mb-2">
                                        <i class="far fa-calendar-alt me-2 text-primary"></i>Échéance : 
                                        <span class="fw-semibold {% if tache.dateFinPrevue < date() and tache.statut != 'terminée' %}text-danger{% endif %}">
                                            {{ tache.dateFinPrevue|date('d/m/Y') }}
                                        </span>
                                    </li>
                                    {% endif %}
                                    <li>
                                        <i class="far fa-clock me-2 text-primary"></i>Temps estimé : <span class="fw-semibold">{{ tache.dureeEstimee }}h</span>
                                    </li>
                                </ul>
                            </div>
                            <div class="card-footer bg-transparent border-top-0 pb-4 pt-0">
                                <a href="{{ path('app_feuille_temps_nouvelle') }}" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-plus me-1"></i> Saisir du temps
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

<style>
    .hover-shadow { transition: box-shadow 0.3s ease-in-out, transform 0.3s ease-in-out; }
    .hover-shadow:hover { box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important; transform: translateY(-5px); }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
{% endblock %}
